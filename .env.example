# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# API Keys
GROQ_API_KEY=gsk_your_groq_api_key
NEWS_API_KEY=your-news-api-key
OPENWEATHER_API_KEY=your-OPENWEATHER_API_KEY-api-key

# ==========================================
# Groq Configuration
# ==========================================
# Recommended default model
GROQ_MODEL=llama-3.3-70b-versatile

# ==========================================
# LLM Usage Guardrails
# ==========================================
# Set to true to enforce limits
LLM_GUARDRAILS_ENABLED=true

# Maximum requests allowed per day
LLM_MAX_REQUESTS_PER_DAY=500

# Maximum input/output tokens allowed per day
LLM_MAX_TOKENS_PER_DAY=500000

# Maximum requests allowed per minute
LLM_MAX_REQUESTS_PER_MINUTE=20

# Maximum concurrent LLM requests
LLM_MAX_CONCURRENT_REQUESTS=2

LLM_PROVIDER=groq

# Application Configuration
LOG_LEVEL=INFO
APP_ENV=development
SUMMARY_INTERVAL=3600
